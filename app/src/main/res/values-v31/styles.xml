<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: black background, the logo as the splash
         icon, then hand off to the launcher (which shows the full logo). -->
    <style name="SplashTheme" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
</resources>
